                        <div className="flex flex-col gap-1 pt-2 border-t border-white/30">
                          <span className="text-white/90 text-sm">Coverage:</span>
                          <span className="font-medium text-sm">{scholarship.coverage}</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>

                <div className="mt-6 p-6 bg-white/50 rounded-2xl border border-[#DCE3F1]">
                  <h5 className="text-lg font-bold text-[#2b2d72] mb-3">How to Apply</h5>
                  <ul className="space-y-2 text-gray-600">
                    <li className="flex items-start gap-2">
                      <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                      <span>Check eligibility criteria on the official scholarship website</span>
                    </li>
                    <li className="flex items-start gap-2">
                      <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                      <span>Most scholarships require admission confirmation first</span>
                    </li>
                    <li className="flex items-start gap-2">
                      <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                      <span>Submit applications early - deadlines are usually 6-12 months before intake</span>
                    </li>
                    <li className="flex items-start gap-2">
                      <CheckCircle className="w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5" />
                      <span>Strong academic records and language proficiency increase chances</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
