          {/* Visa Process */}
          <div id="visa-process" className="bg-white/80 backdrop-blur-md rounded-2xl shadow-xl overflow-hidden border border-[#DCE3F1] scroll-mt-24">
            <button
              onClick={() => toggleAccordion('visa-process')}
              className="w-full px-8 py-6 flex justify-between items-center hover:bg-gradient-to-r hover:from-[#EEF4FF] hover:to-[#DBEAFE] transition-all"
            >
              <div className="flex items-center gap-4">
                <div className="w-12 h-12 bg-gradient-to-br from-[#EF4444] to-[#DC2626] rounded-xl flex items-center justify-center">
                  <FileText className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-2xl font-bold text-[#2b2d72]">Visa Process</h3>
              </div>
              {activeAccordion === 'visa-process' ? (
                <ChevronUp className="w-6 h-6 text-[#2b2d72]" />
              ) : (
                <ChevronDown className="w-6 h-6 text-gray-600" />
              )}
            </button>

            <div
              className={`transition-all duration-500 ease-in-out ${
                activeAccordion === 'visa-process'
                  ? 'max-h-[3000px] opacity-100'
                  : 'max-h-0 opacity-0 overflow-hidden'
              }`}
            >
              <div className="px-8 pb-8">
                <div className="space-y-4">
                  {[
                    {
                      step: 'Step 1',
                      title: 'Campus France Registration',
                      description: 'Create an account on Campus France portal, complete your profile, and submit all academic documents',
                      time: '2-4 weeks',
                      color: 'from-[#3B82F6] to-[#2563EB]'
                    },
                    {
                      step: 'Step 2',
                      title: 'Pedagogical Interview',
                      description: 'Attend an interview at Campus France to discuss your study project and academic goals',
                      time: '1-2 weeks',
                      color: 'from-[#10B981] to-[#059669]'
                    },
                    {
                      step: 'Step 3',
                      title: 'University Admission',
                      description: 'Apply to universities through the Campus France platform and wait for acceptance letters',
                      time: '4-8 weeks',
                      color: 'from-[#F59E0B] to-[#D97706]'
                    },
                    {
                      step: 'Step 4',
                      title: 'Visa Application',
                      description: 'Submit visa application at VFS France with all required documents and biometrics',
                      time: '2-3 weeks',
                      color: 'from-[#8B5CF6] to-[#7C3AED]'
                    },
                    {
                      step: 'Step 5',
                      title: 'OFII Validation',
                      description: 'Upon arrival in France, validate your visa at OFII (French Immigration Office) within 3 months',
