            <div
              className={`transition-all duration-500 ease-in-out ${
                activeAccordion === 'courses'
                  ? 'max-h-[3000px] opacity-100'
                  : 'max-h-0 opacity-0 overflow-hidden'
              }`}
            >
              <div className="px-8 pb-8">
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {[
                    { name: 'Business Management', icon: Briefcase, color: 'from-[#3B82F6] to-[#2563EB]', url: 'https://www.google.com/search?q=Business+Management+France' },
                    { name: 'Fashion Designing', icon: Palette, color: 'from-[#EC4899] to-[#DB2777]', url: 'https://www.google.com/search?q=Fashion+Design+France' },
                    { name: 'Culinary Arts', icon: Utensils, color: 'from-[#F59E0B] to-[#D97706]', url: 'https://www.google.com/search?q=Culinary+Arts+France' },
                    { name: 'Engineering', icon: Building2, color: 'from-[#8B5CF6] to-[#7C3AED]', url: 'https://www.google.com/search?q=Engineering+France' },
                    { name: 'Data Science', icon: Database, color: 'from-[#10B981] to-[#059669]', url: 'https://www.google.com/search?q=Data+Science+France' },
                    { name: 'Artificial Intelligence', icon: Brain, color: 'from-[#06B6D4] to-[#0891B2]', url: 'https://www.google.com/search?q=AI+France' },
                    { name: 'Hospitality', icon: Hotel, color: 'from-[#14B8A6] to-[#0D9488]', url: 'https://www.google.com/search?q=Hospitality+France' },
                    { name: 'Finance', icon: Finance, color: 'from-[#EF4444] to-[#DC2626]', url: 'https://www.google.com/search?q=Finance+France' },
                    { name: 'Arts & Design', icon: Palette, color: 'from-[#A855F7] to-[#9333EA]', url: 'https://www.google.com/search?q=Arts+Design+France' }
                  ].slice(0, showAllCourses ? 9 : 6).map((course, index) => (
                    <a
