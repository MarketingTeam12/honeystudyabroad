                      target="_blank"
                      rel="noopener noreferrer"
                      className="group bg-white hover:bg-gradient-to-br hover:from-[#F8FAFC] hover:to-[#F1F5F9] p-6 rounded-2xl shadow-md hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border-2 border-transparent hover:border-[#356AE6]"
                    >
